          "title": "Reduce to parity",
          "body": [
            {
              "id": "89d95f1a-c527-4f46-8a4d-7422ca1b66a2",
              "block_type": "text",
              "content": {
                "spans": [
                  {
                    "text": "Any even w >= 4 splits as 2 and (w - 2), both even and positive. Odd w can never split into two even parts, and w = 2 only splits as 1 + 1, neither of which is even.",
                    "emphasis": [],
                    "link_target": null
                  }
                ]
              },
              "role": "body"
            }
