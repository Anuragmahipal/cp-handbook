          "id": "a4e2e9be-5f01-49e2-a4d5-d4f8f8eb41e2",
          "block_type": "callout",
          "kind": "pitfall",
          "title": "hi = mid vs. hi = mid - 1",
          "body": [
            {
              "id": "60fd0711-6a4a-490a-8dd2-0af1d3d765c4",
              "block_type": "text",
              "content": {
                "spans": [
                  {
                    "text": "When check(mid) is False, hi must become mid - 1, not mid -- otherwise a two-element range [lo, lo+1] with mid = lo never shrinks and the loop never terminates.",
                    "emphasis": [],
                    "link_target": null
                  }
                ]
              },
              "role": "body"
            }
          ]
        }
      ],
