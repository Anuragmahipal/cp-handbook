        {
          "id": "3b6a2cbd-7982-41ba-953b-4280c3e30ba7",
          "block_type": "code",
          "language": "cpp",
          "source": "int left = 0, right = n - 1;\nwhile (left < right) {\n    int sum = a[left] + a[right];\n    if (sum == target) return true;\n    if (sum < target) left++;\n    else right--;\n}\nreturn false;",
          "caption": "",
