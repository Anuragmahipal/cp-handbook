          "id": "8aed771f-ff32-49ba-b3a8-f78db546748c",
          "block_type": "text",
          "content": {
            "spans": [
              {
                "text": "On a sorted array, if the sum at (left, right) is too big, only shrinking right can help; if it's too small, only growing left can. That one-directional argument is what lets both pointers move only forward, ever.",
                "emphasis": [],
                "link_target": null
              }
            ]
          },
          "role": "intuition"
        }
