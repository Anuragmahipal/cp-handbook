  "metadata": {
    "title": "Two Pointers on a Sorted Array",
    "summary": "Collapsing an O(n²) pair search into O(n) by moving two indices toward each other instead of checking every pair.",
    "tags": [
      "two-pointers",
      "arrays",
      "sorted"
    ],
