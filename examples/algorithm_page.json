  "metadata": {
    "title": "Dijkstra's Algorithm",
    "summary": "Single-source shortest paths on a graph with non-negative edge weights, by always finalizing the closest unvisited node.",
    "tags": [
      "graphs",
      "shortest-path",
      "greedy"
    ],
    "source_kind": "algorithm",
    "difficulty": "Medium",
    "estimated_minutes": 25,
    "locale": "en"
  },
  "sections": [
    {
      "id": "1c6971f2-3839-4712-a495-311f1a9cb619",
      "version": 1,
      "revision_of": null,
      "superseded_by": null,
      "created_at": "2026-07-12T17:49:56.505393",
      "updated_at": "2026-07-12T17:49:56.505395",
      "heading": {
        "spans": [
          {
            "text": "Recognition",
            "emphasis": [],
            "link_target": null
          }
        ]
      },
      "blocks": [
        {
          "id": "a8f70821-df71-4102-9821-fd01db129b59",
          "block_type": "text",
          "content": {
            "spans": [
              {
                "text": "Shortest paths, non-negative weights, one source, possibly many destinations -- that combination is Dijkstra.",
                "emphasis": [],
                "link_target": null
              }
            ]
          },
          "role": "intuition"
        },
        {
          "id": "b3682cfe-8ae4-4c80-ab5c-70070ffe3b76",
          "block_type": "callout",
          "kind": "insight",
          "title": "When it stops applying",
          "body": [
            {
              "id": "5905c396-97e9-4a4a-a2bb-1611ce251e5d",
              "block_type": "text",
              "content": {
                "spans": [
                  {
                    "text": "The moment an edge weight can be negative, the greedy argument breaks and you need Bellman-Ford instead.",
                    "emphasis": [],
                    "link_target": null
                  }
                ]
              },
              "role": "body"
            }
          ]
        }
      ],
      "memory_anchors": [],
      "review_cues": []
    },
    {
      "id": "e623749b-71b2-4371-8694-022330679e17",
      "version": 1,
      "revision_of": null,
      "superseded_by": null,
      "created_at": "2026-07-12T17:49:56.505453",
      "updated_at": "2026-07-12T17:49:56.505454",
      "heading": {
        "spans": [
          {
            "text": "Core Idea",
            "emphasis": [],
            "link_target": null
          }
        ]
      },
      "blocks": [
        {
          "id": "e14ade32-6898-419d-b8e6-38b154cbfc20",
          "block_type": "text",
          "content": {
            "spans": [
              {
                "text": "Repeatedly pop the closest unvisited node from a priority queue, finalize its distance, and relax every edge out of it.",
                "emphasis": [],
                "link_target": null
              }
            ]
          },
          "role": "body"
        },
        {
          "id": "637915d3-ba61-4709-b420-00c1f5a8d9c9",
          "block_type": "callout",
          "kind": "definition",
          "title": "Relaxation",
          "body": [
            {
              "id": "344ace62-9ad4-4e40-8162-218f7335fe77",
              "block_type": "text",
              "content": {
                "spans": [
                  {
                    "text": "Relaxing edge (u, v, w) means: if dist[u] + w < dist[v], improve dist[v] and push it back onto the queue.",
                    "emphasis": [],
                    "link_target": null
                  }
                ]
              },
              "role": "body"
            }
          ]
        }
      ],
      "memory_anchors": [],
      "review_cues": []
    },
    {
      "id": "6152ab81-96ca-4b31-9feb-bcc56b5cc0c2",
      "version": 1,
      "revision_of": null,
      "superseded_by": null,
      "created_at": "2026-07-12T17:49:56.505474",
      "updated_at": "2026-07-12T17:49:56.505475",
      "heading": {
        "spans": [
          {
            "text": "Complexity",
            "emphasis": [],
            "link_target": null
          }
        ]
      },
      "blocks": [
        {
          "id": "87ec1156-2dfd-4e3d-bc00-b955b749f801",
          "block_type": "text",
          "content": {
            "spans": [
              {
                "text": "O((V + E) log V) with a binary heap -- each edge can trigger at most one push, and each push costs log V.",
                "emphasis": [],
                "link_target": null
              }
            ]
          },
          "role": "body"
        }
      ],
